# Git ignore for blockchain-explorer project

################################
# Environment / secrets        #
################################

# Local env files (do not commit real secrets)
.env
.env.*
secrets/

################################
# Go build artifacts           #
################################

/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

################################
# Dependencies / caches        #
################################

vendor/
node_modules/
package-lock.json

################################
# Archives / installers        #
################################

*.tar.gz
*.zip

################################
# Docker / data volumes        #
################################

docker-compose.override.yml
**/db-data/
**/redis-data/

################################
# Playwright                   #
################################

playwright-report/
test-results/
blob-report/

################################
# Logs / coverage              #
################################

*.log
logs/
coverage.out
coverage.html

################################
# OS / editor junk             #
################################

.DS_Store
.vscode/
.idea/
*.swp

################################
# Build artifacts / dist       #
################################

dist/
build/

################################
# Large or binary assets       #
################################

*.jpg
*.jpeg
*.png
*.gif

################################
# Misc project-specific        #
################################

# API test results (currently tracked intentionally)
# Uncomment the next line if you prefer to keep them local-only.
# API_TEST_RESULTS.md

# Local temp / generated (do not track)
.tmp/

# Built binaries (build from source: go build -o blockchain-explorer ./cmd/server)
blockchain-explorer
bitcoin-explorer
/server

