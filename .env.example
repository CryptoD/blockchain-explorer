###############################
# Core application settings   #
###############################

# Environment name for the app (used for logging/behavior switches)
# e.g. development, staging, production
APP_ENV=development

###############################
# Backend HTTP configuration  #
###############################

# Port the Go Gin server listens on inside the container/host
APP_PORT=8080

###############################
# Redis configuration         #
###############################

# Hostname of the Redis instance (matches docker-compose service name in dev)
REDIS_HOST=redis

# Connection pool (go-redis). POOL_SIZE 0 = library default (10×GOMAXPROCS). MAX_ACTIVE_CONNS 0 = unlimited.
# REDIS_POOL_SIZE=32
# REDIS_MAX_ACTIVE_CONNS=128
# REDIS_DIAL_TIMEOUT_SECONDS=5
# REDIS_READ_TIMEOUT_SECONDS=5
# REDIS_WRITE_TIMEOUT_SECONDS=5
# REDIS_POOL_TIMEOUT_SECONDS=0
# REDIS_CONN_MAX_IDLE_SECONDS=300
# REDIS_MIN_IDLE_CONNS=2

# Shared HTTP client (JSON-RPC, CoinGecko, news). Timeout default 30s matches JSON-RPC handler budget.
# OUTBOUND_HTTP_TIMEOUT_SECONDS=30
# OUTBOUND_HTTP_DIAL_TIMEOUT_SECONDS=10
# OUTBOUND_HTTP_RESPONSE_HEADER_TIMEOUT_SECONDS=30
# OUTBOUND_HTTP_MAX_CONNS_PER_HOST=64
# OUTBOUND_HTTP_MAX_IDLE_CONNS=128
# OUTBOUND_HTTP_MAX_IDLE_CONNS_PER_HOST=32
# OUTBOUND_HTTP_IDLE_CONN_TIMEOUT_SECONDS=90

###############################
# PostgreSQL configuration    #
###############################

# Database connection settings (used by Docker Compose and future DB integration)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres

# Application database name
DB_NAME=blockchain_explorer

# Shared Postgres password for app and DB container
POSTGRES_PASSWORD=change_me_strong_password

###############################
# GetBlock / Bitcoin RPC      #
###############################

# Required: base URL for the GetBlock (or compatible) Bitcoin JSON-RPC endpoint.
# Example: https://go.getblock.io/your-project-id
GETBLOCK_BASE_URL=https://go.getblock.io/your-project-id

# Required: access token or API key for the GetBlock endpoint.
GETBLOCK_ACCESS_TOKEN=your-getblock-access-token

###############################
# Sentry error tracking       #
###############################

# Optional: Sentry DSN for error tracking.
# Leave empty to disable Sentry in local development.
SENTRY_DSN=

###############################
# Admin user configuration    #
###############################

# Admin username created at startup if it doesn't already exist.
# In non-development environments (APP_ENV != development), this MUST be set.
ADMIN_USERNAME=admin

# Admin password for the initial admin user.
# In non-development environments, this MUST be set to a strong, unique value.
ADMIN_PASSWORD=change_me_admin_password

###############################
# Email delivery (SMTP)       #
###############################
#
# Provider selector (future-proofing)
EMAIL_PROVIDER=smtp
#
# From address used for outgoing emails
EMAIL_FROM=alerts@example.com
EMAIL_FROM_NAME=Blockchain Explorer
#
# Admin email for critical notifications
ADMIN_EMAIL=admin@example.com
#
# SMTP connection settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
#
# STARTTLS is recommended for port 587
SMTP_STARTTLS=true
#
# Skip TLS certificate verification — ONLY with APP_ENV=development (self-signed / lab SMTP).
# Production/staging will refuse to start if this is true. See docs/SMTP_TLS.md.
SMTP_SKIP_VERIFY=false
#
# Base URL used in email templates (optional)
APP_BASE_URL=http://localhost:8080

###############################
# Frontend / misc             #
###############################

# Optional Redis URL used by some tooling or alternate setups.
# Not currently consumed directly by main.go but documented for completeness.
REDIS_URL=redis://redis:6379

###############################
# Financial news provider     #
###############################
#
# Selected provider: TheNewsAPI (https://www.thenewsapi.com/)
# - Clear plan-based quotas (Free: 100 requests/day; paid tiers increase significantly)
# - Query language supports symbol/keyword filtering via the `search` parameter (AND/OR/NOT, phrases)
#
# Provider selector (future-proofing if additional providers are added later).
NEWS_PROVIDER=thenewsapi
#
# TheNewsAPI authentication token (api_token query parameter).
THENEWSAPI_API_TOKEN=your_thenewsapi_token
#
# Base URL for the provider.
THENEWSAPI_BASE_URL=https://api.thenewsapi.com
#
# Default search query used for general crypto/market news. URL-encode when used in requests.
# Example: bitcoin + (btc | "bitcoin price") -scam
THENEWSAPI_DEFAULT_SEARCH=bitcoin + (btc | "bitcoin price")
#
# Optional defaults for filtering.
THENEWSAPI_DEFAULT_LANGUAGE=en
THENEWSAPI_DEFAULT_LOCALE=us
THENEWSAPI_DEFAULT_CATEGORIES=business,tech

# Cache behavior
# - "fresh" cache: used when provider is healthy
# - "stale" cache: used when provider errors or rate-limits
NEWS_CACHE_TTL_SECONDS=300
NEWS_STALE_TTL_SECONDS=3600

