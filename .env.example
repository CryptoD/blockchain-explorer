###############################
# Core application settings   #
###############################

# Environment name for the app (used for logging/behavior switches)
# e.g. development, staging, production
APP_ENV=development

###############################
# Backend HTTP configuration  #
###############################

# Port the Go Gin server listens on inside the container/host
APP_PORT=8080

###############################
# Redis configuration         #
###############################

# Hostname of the Redis instance (matches docker-compose service name in dev)
REDIS_HOST=redis

###############################
# PostgreSQL configuration    #
###############################

# Database connection settings (used by Docker Compose and future DB integration)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres

# Application database name
DB_NAME=blockchain_explorer

# Shared Postgres password for app and DB container
POSTGRES_PASSWORD=change_me_strong_password

###############################
# GetBlock / Bitcoin RPC      #
###############################

# Required: base URL for the GetBlock (or compatible) Bitcoin JSON-RPC endpoint.
# Example: https://go.getblock.io/your-project-id
GETBLOCK_BASE_URL=https://go.getblock.io/your-project-id

# Required: access token or API key for the GetBlock endpoint.
GETBLOCK_ACCESS_TOKEN=your-getblock-access-token

###############################
# Sentry error tracking       #
###############################

# Optional: Sentry DSN for error tracking.
# Leave empty to disable Sentry in local development.
SENTRY_DSN=

###############################
# Admin user configuration    #
###############################

# Default admin username created at startup if not already present.
ADMIN_USERNAME=admin

# Default admin password for the initial admin user.
# Change this immediately in any non-development environment.
ADMIN_PASSWORD=change_me_admin_password

###############################
# Frontend / misc             #
###############################

# Optional Redis URL used by some tooling or alternate setups.
# Not currently consumed directly by main.go but documented for completeness.
REDIS_URL=redis://redis:6379

# Copy this file to .env and fill the secrets for local development

# Postgres
POSTGRES_PASSWORD=changeme

# GetBlock API (required for blockchain data)
GETBLOCK_BASE_URL=https://go.getblock.io/YOUR_PROJECT_ID
GETBLOCK_ACCESS_TOKEN=your_getblock_api_key

# Optional: other envs
# REDIS_HOST=redis
# DB_NAME=blockchain_explorer
